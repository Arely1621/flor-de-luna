extends ../layout

block contenido

  h2.text-center.mb-4
    | Agregar Producto🌸

  .card.mb-5.shadow

    .card-header
      | Agregar producto

    .card-body

      form(
        action="/admin/crear-producto"
        method="POST"
        enctype="multipart/form-data"
      )

        .row.g-3

          .col-md-3
            input.form-control(
              type="text"
              name="nombre"
              placeholder="Nombre"
              required
            )

          .col-md-2
            input.form-control(
              type="number"
              step="0.01"
              name="precio"
              placeholder="Precio"
              required
            )

          .col-md-3
            input.form-control(
              type="text"
              name="descripcion"
              placeholder="Descripción"
            )

          .col-md-2
            select.form-select(name="categoria")
              option(value="flor") Flor
              option(value="ramo") Ramo

          .col-md-2
            select.form-select(name="ocasion")
              option(value="") Sin ocasión
              option(value="sanvalentin") San Valentín
              option(value="cumple") Cumpleaños
              option(value="aniversario") Aniversario
              option(value="madres") Día de las madres
              option(value="graduacion") Graduación
              option(value="baby") Baby Shower

          .col-md-12
            input.form-control(
              type="file"
              name="imagen"
              required
            )

        button.btn.btn-primary.mt-3(
          type="submit"
        ) Guardar producto

  table.table.table-striped.align-middle

    thead
      tr
        th Imagen
        th Nombre
        th Precio
        th Categoría
        th Ocasión
        th

    tbody

      each p in productos

        tr

          td
            img(
              src=`/img/${p.imagen}`
              width="70"
              style="border-radius:10px"
            )

          td= p.nombre

          td
            | $#{p.precio}

          td= p.categoria

          td= p.ocasion

          td

            a.btn.btn-warning.btn-sm(
              href=`/admin/editar-producto/${p.id}`
            ) Editar

            a.btn.btn-danger.btn-sm.ms-2(
              href=`/admin/eliminar-producto/${p.id}`
            ) Eliminar
