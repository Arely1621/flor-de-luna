extends layout

block contenido

  .container.mt-5

    .row.justify-content-center

      .col-md-7

        .card.shadow

          .card-body

            h2.text-center.mb-4
              | Editar perfil 🌸

            form(
              action="/perfil/editar"
              method="POST"
            )

              .mb-3

                label.form-label Nombre

                input.form-control(
                  type="text"
                  name="nombre"
                  value=usuario.nombre
                )

              .mb-3

                label.form-label Email

                input.form-control(
                  type="email"
                  name="email"
                  value=usuario.email
                )

              .mb-3

                label.form-label Teléfono

                input.form-control(
                  type="text"
                  name="telefono"
                  value=usuario.telefono
                )

              .mb-3

                label.form-label Dirección

                input.form-control(
                  type="text"
                  name="direccion"
                  value=usuario.direccion
                )

              .mb-3

                label.form-label Ciudad

                input.form-control(
                  type="text"
                  name="ciudad"
                  value=usuario.ciudad
                )

              .mb-3

                label.form-label Código Postal

                input.form-control(
                  type="text"
                  name="codigoPostal"
                  value=usuario.codigoPostal
                )

              .d-flex.gap-3

                button.btn.btn-success.w-50(
                  type="submit"
                )
                  | Guardar

                a.btn.btn-secondary.w-50(
                  href="/perfil"
                )
                  | Cancelar